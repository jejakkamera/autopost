# ============================================
# AutoBlog AI — Environment Configuration
# ============================================
# Salin file ini menjadi .env dan isi dengan kredensial Anda.
# cp .env.example .env

# Google Gemini API Key (dari Google AI Studio: https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Blog ID Blogspot (dari URL dashboard Blogger: https://www.blogger.com/blog/posts/BLOG_ID)
BLOG_ID=your_blog_id_here

# OAuth2 Client (dari Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here

# Server Configuration
HOST=127.0.0.1
PORT=8000
